<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_main">

    <!-- TITLE -->
    <TextView
        android:id="@+id/tvTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Custom 1"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/peach_primary"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="32dp"/>

    <!-- IMAGE -->
    <ImageView
        android:id="@+id/imgCustom"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/logo_home"
        android:scaleType="fitCenter"
        app:layout_constraintTop_toBottomOf="@id/tvTitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

    <!-- DESCRIPTION -->
    <TextView
        android:id="@+id/tvDesc"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Halaman ini menampilkan informasi tambahan mengenai bangun ruang secara lebih interaktif.
                      Pengguna dapat melihat penjelasan konsep, contoh penerapan dalam kehidupan sehari-hari,
                      serta visualisasi sederhana untuk membantu memahami materi dengan lebih mudah dan menarik."
        android:textColor="@color/text_dark"
        android:gravity="center"
        android:layout_margin="24dp"
        app:layout_constraintTop_toBottomOf="@id/imgCustom"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- BUTTON BACK -->
    <Button
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Kembali"
        app:layout_constraintTop_toBottomOf="@id/tvDesc"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="24dp"/>

</androidx.constraintlayout.widget.ConstraintLayout>