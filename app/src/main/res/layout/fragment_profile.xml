<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF7F0"
    android:padding="20dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerProfile"
        android:layout_width="0dp"
        android:layout_height="150dp"
        android:background="#2D6A4F"
        android:elevation="8dp"
        android:padding="18dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvTitleProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Profil Pengembang"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/tvSubProfile"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:text="Informasi pembuat aplikasi"
            android:textColor="#D8F3DC"
            android:textSize="14sp"
            app:layout_constraintTop_toBottomOf="@id/tvTitleProfile"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ImageView
        android:id="@+id/imgProfile"
        android:layout_width="110dp"
        android:layout_height="110dp"
        android:layout_marginTop="-55dp"
        android:background="#FFFFFF"
        android:elevation="10dp"
        android:padding="4dp"
        android:scaleType="centerCrop"
        android:src="@drawable/zora_profile"
        app:layout_constraintTop_toBottomOf="@id/headerProfile"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cardProfile"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="24dp"
        android:background="#FFFFFF"
        android:elevation="5dp"
        android:padding="20dp"
        app:layout_constraintTop_toBottomOf="@id/imgProfile"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/valueNama"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Ozora Feona Surya"
            android:textColor="#1B4332"
            android:textSize="22sp"
            android:textStyle="bold"
            android:gravity="center"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/valueRole"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Android Developer"
            android:textColor="#52796F"
            android:textSize="15sp"
            android:gravity="center"
            app:layout_constraintTop_toBottomOf="@id/valueNama"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/valueNim"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="22dp"
            android:text="NIM: 2457301118"
            android:textColor="#1B4332"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/valueRole"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/valueKelas"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Kelas: 2 SI C"
            android:textColor="#1B4332"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/valueNim"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <TextView
            android:id="@+id/valueProdi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:text="Prodi: Sistem Informasi"
            android:textColor="#1B4332"
            android:textSize="16sp"
            app:layout_constraintTop_toBottomOf="@id/valueKelas"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnGithub"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#24292F"
            android:text="GitHub"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:cornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@id/valueProdi"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnLinkedin" />

        <Button
            android:id="@+id/btnLinkedin"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#0A66C2"
            android:text="LinkedIn"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:cornerRadius="16dp"
            app:layout_constraintTop_toTopOf="@id/btnGithub"
            app:layout_constraintStart_toEndOf="@id/btnGithub"
            app:layout_constraintEnd_toEndOf="parent" />

        <Button
            android:id="@+id/btnInstagram"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:layout_marginEnd="8dp"
            android:backgroundTint="#E1306C"
            android:text="Instagram"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:cornerRadius="16dp"
            app:layout_constraintTop_toBottomOf="@id/btnGithub"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnWhatsapp" />

        <Button
            android:id="@+id/btnWhatsapp"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_marginStart="8dp"
            android:backgroundTint="#25D366"
            android:text="WhatsApp"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            app:cornerRadius="16dp"
            app:layout_constraintTop_toTopOf="@id/btnInstagram"
            app:layout_constraintStart_toEndOf="@id/btnInstagram"
            app:layout_constraintEnd_toEndOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>