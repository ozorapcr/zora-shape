<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp">

    <TextView
        android:id="@+id/tvTitleOtp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Verifikasi OTP"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tvDescOtp"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="Masukkan kode OTP (gunakan nomor HP kamu)"
        android:layout_marginTop="10dp"
        app:layout_constraintTop_toBottomOf="@id/tvTitleOtp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <EditText
        android:id="@+id/inputOtp"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:hint="Masukkan OTP"
        android:inputType="number"
        android:layout_marginTop="30dp"
        android:padding="12dp"
        app:layout_constraintTop_toBottomOf="@id/tvDescOtp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <Button
        android:id="@+id/btnVerifikasi"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:text="Verifikasi"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/inputOtp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>