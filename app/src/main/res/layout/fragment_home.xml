<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#EEF7F0"
    android:padding="20dp">

    <!-- HEADER -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/headerCard"
        android:layout_width="0dp"
        android:layout_height="150dp"
        android:background="#2D6A4F"
        android:elevation="8dp"
        android:padding="18dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvWelcomeUser"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Halo, User!"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <TextView
            android:id="@+id/tvSubtitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Selamat datang di aplikasi Bina Desa"
            android:textSize="14sp"
            android:textColor="#D8F3DC"
            android:layout_marginTop="6dp"
            app:layout_constraintTop_toBottomOf="@id/tvWelcomeUser"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- MENU TITLE -->
    <TextView
        android:id="@+id/tvMenu"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Menu"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#1B4332"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/headerCard"
        app:layout_constraintStart_toStartOf="parent"/>

    <!-- ROW 1 -->
    <Button
        android:id="@+id/btnRumus"
        android:layout_width="0dp"
        android:layout_height="65dp"
        android:text="Rumus"
        android:textAllCaps="false"
        android:backgroundTint="#2D6A4F"
        android:textColor="#FFFFFF"
        app:cornerRadius="14dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvMenu"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnCustom1"/>

    <Button
        android:id="@+id/btnCustom1"
        android:layout_width="0dp"
        android:layout_height="65dp"
        android:text="Custom 1"
        android:textAllCaps="false"
        android:backgroundTint="#40916C"
        android:textColor="#FFFFFF"
        app:cornerRadius="14dp"
        android:layout_marginTop="12dp"
        android:layout_marginStart="6dp"
        app:layout_constraintTop_toBottomOf="@id/tvMenu"
        app:layout_constraintStart_toEndOf="@id/btnRumus"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- ROW 2 -->
    <Button
        android:id="@+id/btnCustom2"
        android:layout_width="0dp"
        android:layout_height="65dp"
        android:text="Custom 2"
        android:textAllCaps="false"
        android:backgroundTint="#52B788"
        android:textColor="#FFFFFF"
        app:cornerRadius="14dp"
        android:layout_marginTop="10dp"
        android:layout_marginEnd="6dp"
        app:layout_constraintTop_toBottomOf="@id/btnRumus"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/btnWeb"/>

    <Button
        android:id="@+id/btnWeb"
        android:layout_width="0dp"
        android:layout_height="65dp"
        android:text="Web Bina Desa"
        android:textAllCaps="false"
        android:backgroundTint="#74C69D"
        android:textColor="#FFFFFF"
        app:cornerRadius="14dp"
        android:layout_marginTop="10dp"
        android:layout_marginStart="6dp"
        app:layout_constraintTop_toBottomOf="@id/btnCustom1"
        app:layout_constraintStart_toEndOf="@id/btnCustom2"
        app:layout_constraintEnd_toEndOf="parent"/>

    <!-- LOGOUT -->
    <Button
        android:id="@+id/btnLogout"
        android:layout_width="0dp"
        android:layout_height="55dp"
        android:text="Logout"
        android:textAllCaps="false"
        android:backgroundTint="#D62828"
        android:textColor="#FFFFFF"
        app:cornerRadius="16dp"
        android:layout_marginTop="18dp"
        app:layout_constraintTop_toBottomOf="@id/btnCustom2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>